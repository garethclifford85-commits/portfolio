---
import { site } from '../data/site.js';
---

<section class="work" id="work" aria-labelledby="work-heading">
  <div class="work__header container">
    <p class="section-label" data-reveal>Selected Projects</p>
    <h2 class="section-heading work__heading" id="work-heading" data-reveal>
      My work<span class="accent-dot">.</span>
    </h2>
  </div>

  <div class="work__grid container" data-reveal-group>
    {site.projects.map((project, i) => (
      <article
        class={`project-tile project-tile--${i + 1}${project.imageFlip ? ' project-tile--flipped' : ''}`}
        aria-label={project.title}
      >
        <div
          class="project-tile__bg"
          style={
            project.imageSrc
              ? `background-image: url(${project.imageSrc});${project.imagePosition ? ` background-position: ${project.imagePosition};` : ''}`
              : `background: ${project.gradient}`
          }
          role="img"
          aria-label={project.imageAlt}
        />

        <div class="project-tile__content">
          <h3 class="project-tile__title">{project.title}</h3>
          <p class="project-tile__result">{project.result}</p>

          <div class="project-tile__reveal">
            <div class="project-tile__reveal-inner">
              <p class="project-tile__detail">{project.detail}</p>
              {project.gallery && project.gallery.length > 0 ? (
                <button
                  class="project-tile__cta"
                  data-gallery-open={JSON.stringify(project.gallery)}
                  tabindex="-1"
                >
                  {project.ctaLabel || 'View gallery'}
                  <span aria-hidden="true">↗</span>
                </button>
              ) : project.ctaUrl ? (
                <a
                  href={project.ctaUrl}
                  class="project-tile__cta"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${project.ctaLabel} for ${project.title}`}
                  tabindex="-1"
                >
                  {project.ctaLabel}
                  <span aria-hidden="true">↗</span>
                </a>
              ) : null}
            </div>
          </div>
        </div>

      </article>
    ))}
  </div>
</section>

<!-- Lightbox gallery -->
<div
  id="gallery-lightbox"
  class="gallery-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Image gallery"
  aria-hidden="true"
>
  <button class="gallery-close" id="gallery-close" aria-label="Close gallery">&#x2715;</button>
  <button class="gallery-prev"  id="gallery-prev"  aria-label="Previous image">&#8249;</button>
  <div class="gallery-img-wrap">
    <img id="gallery-img" src="" alt="" />
  </div>
  <button class="gallery-next"  id="gallery-next"  aria-label="Next image">&#8250;</button>
  <p class="gallery-counter" id="gallery-counter" aria-live="polite"></p>
</div>

<script>
  const lightbox  = document.getElementById('gallery-lightbox');
  const img       = document.getElementById('gallery-img') as HTMLImageElement;
  const counter   = document.getElementById('gallery-counter');

  let images: string[] = [];
  let current = 0;

  function show(index: number) {
    current = ((index % images.length) + images.length) % images.length;
    img.style.opacity = '0';
    img.onload = () => { img.style.opacity = '1'; };
    img.src = images[current];
    if (counter) counter.textContent = `${current + 1} / ${images.length}`;
  }

  function open(imgs: string[]) {
    images = imgs;
    show(0);
    lightbox?.removeAttribute('aria-hidden');
    lightbox?.classList.add('gallery-lightbox--open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox?.setAttribute('aria-hidden', 'true');
    lightbox?.classList.remove('gallery-lightbox--open');
    document.body.style.overflow = '';
  }

  // Open gallery on tile CTA click
  document.querySelectorAll<HTMLElement>('[data-gallery-open]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const imgs: string[] = JSON.parse(btn.dataset.galleryOpen ?? '[]');
      open(imgs);
    });
  });

  document.getElementById('gallery-close')?.addEventListener('click', close);
  document.getElementById('gallery-prev')?.addEventListener('click', () => show(current - 1));
  document.getElementById('gallery-next')?.addEventListener('click', () => show(current + 1));

  // Click backdrop to close
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('gallery-lightbox--open')) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>

<style>
  .work {
    padding-top: var(--space-16);
    padding-bottom: var(--space-32);
  }

  .work__header {
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .work__heading {
    font-size: var(--text-4xl);
  }

  .accent-dot {
    color: var(--accent);
  }

  /* ---- Grid ---- */
  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .work__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .work__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 340px;
    }

    /* Asymmetric layout */
    .project-tile--1 { grid-column: 1 / 3; }
    .project-tile--2 { grid-column: 3 / 4; grid-row: 1 / 3; }
    .project-tile--3 { grid-column: 1 / 2; }
    .project-tile--4 { grid-column: 2 / 3; }
    .project-tile--5 { grid-column: 1 / 3; }
    .project-tile--6 { grid-column: 3 / 4; }
  }

  /* ---- Tile ---- */
  .project-tile {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    min-height: 300px;
    cursor: pointer;
  }

  @media (min-width: 640px) {
    .project-tile { min-height: 340px; }
  }

  .project-tile__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.7s var(--ease-out);
  }

  .project-tile:hover .project-tile__bg {
    transform: scale(1.07);
  }

  .project-tile--flipped .project-tile__bg {
    transform: scaleX(-1);
  }

  .project-tile--flipped:hover .project-tile__bg {
    transform: scaleX(-1) scale(1.07);
  }

  /* Dark overlay */
  .project-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(9, 9, 9, 0.92) 0%,
      rgba(9, 9, 9, 0.4) 50%,
      rgba(9, 9, 9, 0.08) 100%
    );
    transition: background 0.4s ease;
  }

  .project-tile:hover::after {
    background: linear-gradient(
      to top,
      rgba(9, 9, 9, 0.97) 0%,
      rgba(9, 9, 9, 0.65) 60%,
      rgba(9, 9, 9, 0.15) 100%
    );
  }

  /* Accent bar slides in from left on hover */
  .project-tile::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    z-index: 3;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.45s var(--ease-out);
  }

  .project-tile:hover::before {
    transform: scaleX(1);
  }

  .project-tile__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
  }

  .project-tile__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-xl);
    line-height: 1.1;
    margin-bottom: 0.3rem;
    color: #f2efe9;
  }

  .project-tile__result {
    font-size: var(--text-sm);
    font-weight: 500;
    color: #f2efe9;
  }

  /* ---- Reveal container ---- */
  .project-tile__reveal {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.45s var(--ease-out), opacity 0.4s ease;
  }

  .project-tile__reveal-inner {
    display: flex;
    flex-direction: column;
    padding-top: 0.75rem;
  }

  .project-tile__detail {
    font-size: var(--text-sm);
    color: rgba(242, 239, 233, 0.78);
    line-height: 1.55;
  }

  .project-tile__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.875rem;
    padding: 0.55rem 1.1rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: #ffffff;
    background: transparent;
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    border-radius: 3px;
    min-height: 44px;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s var(--ease-out);
  }

  .project-tile__cta:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #ffffff;
    transform: translateY(-1px);
  }

  /* Mobile: stacked layout so content can never be clipped */
  @media (max-width: 639px) {
    .project-tile {
      min-height: 0;
      display: flex;
      flex-direction: column;
    }

    /* Image becomes a fixed-height block at the top */
    .project-tile__bg {
      position: relative;
      height: 200px;
      flex-shrink: 0;
    }

    /* No dark gradient needed — content sits below the image */
    .project-tile::after {
      display: none;
    }

    /* Content flows naturally below the image */
    .project-tile__content {
      position: static;
      padding: 1.25rem;
      background: var(--surface-2);
    }

    .project-tile__title,
    .project-tile__result {
      color: var(--text);
    }

    .project-tile__detail {
      color: var(--text-muted);
    }

    /* Always visible, unconstrained height */
    .project-tile__reveal {
      max-height: none;
      opacity: 1;
    }
  }

  /* Tablet: overlay layout, always show reveal */
  @media (min-width: 640px) and (max-width: 767px) {
    .project-tile__reveal {
      max-height: 300px;
      opacity: 1;
    }
  }

  /* Desktop: reveal on hover/focus */
  @media (min-width: 768px) {
    .project-tile:hover .project-tile__reveal,
    .project-tile:focus-within .project-tile__reveal {
      max-height: 300px;
      opacity: 1;
    }
  }

  /* Ghost number — large, behind content, adds editorial depth */
  .project-tile__index {
    position: absolute;
    bottom: -0.05em;
    right: 0.4rem;
    z-index: 1;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(5rem, 12vw, 9rem);
    line-height: 1;
    letter-spacing: -0.05em;
    color: rgba(255, 255, 255, 0.06);
    pointer-events: none;
    user-select: none;
    transition: color 0.4s ease;
  }

  .project-tile:hover .project-tile__index {
    color: rgba(255, 255, 255, 0.1);
  }

  /* ---- Lightbox ---- */
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .gallery-lightbox--open {
    opacity: 1;
    pointer-events: all;
  }

  .gallery-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: calc(100vw - 8rem);
    max-height: calc(100vh - 6rem);
  }

  #gallery-img {
    max-width: 100%;
    max-height: calc(100vh - 6rem);
    object-fit: contain;
    border-radius: 4px;
    transition: opacity 0.2s ease;
    display: block;
  }

  .gallery-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 44px;
    height: 44px;
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }

  .gallery-close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    transform: rotate(90deg);
  }

  .gallery-prev,
  .gallery-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    font-size: 2.5rem;
    line-height: 1;
    color: rgba(255, 255, 255, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: color 0.2s ease, background 0.2s ease;
    cursor: pointer;
    user-select: none;
  }

  .gallery-prev { left: 0.75rem; }
  .gallery-next { right: 0.75rem; }

  .gallery-prev:hover,
  .gallery-next:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
  }

  .gallery-counter {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.08em;
    white-space: nowrap;
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .gallery-img-wrap {
      width: 100vw;
    }

    .gallery-prev { left: 0.25rem; }
    .gallery-next { right: 0.25rem; }
  }
</style>
