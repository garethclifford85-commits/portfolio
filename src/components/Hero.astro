---
import { site } from '../data/site.js';

// Split name into first / last for differential type treatment
const words = site.name.trim().split(/\s+/);
const firstName = words[0];
const lastName  = words.slice(1).join(' ');
---

<section class="hero" aria-label="Introduction">
  <!-- Aurora background effect — pure CSS recreation, no libraries needed -->
  <div class="hero__aurora" aria-hidden="true"></div>

  <div class="hero__inner container">

    <div class="hero__content">
      <p class="hero__label section-label" aria-hidden="true">Portfolio</p>

      <h1 class="hero__name">
        <!-- overflow:hidden on each line creates the curtain-reveal effect -->
        <span class="hero__name-line">
          <span class="hero__name-first">{firstName}</span>
        </span>
        <span class="hero__name-line">
          <span class="hero__name-last">{lastName}</span>
        </span>
      </h1>

      <p class="hero__positioning">
        {site.positioning}
      </p>

      <div class="hero__ctas">
        <a href="#work" class="btn btn--primary">See the work</a>
        <a href="#contact" class="btn btn--outline">Get in touch</a>
        {site.cvUrl && (
          <a href={site.cvUrl} download class="btn btn--outline">Download CV</a>
        )}
      </div>
    </div>

    <!-- Geometric accent: two concentric rings, slowly rotating -->
    <div class="hero__accent" aria-hidden="true">
      <div class="hero__accent-ring hero__accent-ring--outer"></div>
      <div class="hero__accent-ring hero__accent-ring--inner"></div>
    </div>

  </div>

</section>

<style>
  /* ---- Hero shell ---- */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: 7rem;
    overflow: hidden;
    /* Subtle dot-grid texture — no external image needed */
    background-color: var(--bg);
    background-image: radial-gradient(circle, rgba(238,238,238,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .hero__inner {
    position: relative;
    padding-bottom: var(--space-16);
    z-index: 1;
  }

  /* ---- Label ---- */
  .hero__label {
    margin-bottom: var(--space-8);
    animation: fadeUp 0.6s var(--ease-out) both;
  }

  /* ---- Name ---- */
  .hero__name {
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-hero);
    line-height: 0.88;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-10);
  }

  /* Each line clips its child so the slide-up reads as a curtain reveal */
  .hero__name-line {
    display: block;
    overflow: hidden;
    /* Small extra padding so descenders aren't clipped */
    padding-bottom: 0.06em;
  }

  .hero__name-first {
    display: block;
    color: var(--text);
    animation: slideUp 1s 0.05s var(--ease-out) both;
  }

  /* Last name renders as outlined text — bold typographic contrast */
  .hero__name-last {
    display: block;
    -webkit-text-stroke: 2px var(--text);
    color: transparent;
    animation: slideUp 1.05s 0.2s var(--ease-out) both;
    transition: -webkit-text-stroke-color 0.4s ease;
  }

  .hero__name:hover .hero__name-last {
    -webkit-text-stroke-color: var(--accent);
  }

  /* ---- Positioning line ---- */
  .hero__positioning {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--text-muted);
    max-width: 50ch;
    line-height: 1.5;
    white-space: pre-line;
    animation: fadeUp 0.8s 0.32s var(--ease-out) both;
    margin-bottom: var(--space-12);
  }

  /* ---- Credential ---- */
  .hero__credential {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1.25rem;
    border-radius: 4px;
    animation: fadeUp 0.8s 0.42s var(--ease-out) both;
    margin-bottom: var(--space-12);
    max-width: 52ch;
  }

  .hero__credential-marker {
    color: var(--accent);
    font-size: 0.75em;
    flex-shrink: 0;
    line-height: 1;
  }

  /* ---- CTA row ---- */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    animation: fadeUp 0.8s 0.54s var(--ease-out) both;
  }

  /* ---- Geometric accent rings ---- */
  .hero__accent {
    position: absolute;
    top: -20%;
    right: -12%;
    width: clamp(280px, 52vw, 780px);
    height: clamp(280px, 52vw, 780px);
    pointer-events: none;
  }

  .hero__accent-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 224, 194, 0.15);
    animation: ringRotate 80s linear infinite;
  }

  .hero__accent-ring--inner {
    inset: 12%;
    border-color: rgba(255, 224, 194, 0.07);
    animation-duration: 55s;
    animation-direction: reverse;
  }

  @keyframes ringRotate {
    to { transform: rotate(360deg); }
  }


  /* ---- Aurora ---- */
  .hero__aurora {
    position: absolute;
    inset: -10px;
    z-index: 0;
    /* Two layers: a dark base + the colour gradients */
    background-image:
      repeating-linear-gradient(100deg, #000 0%, #000 7%, transparent 10%, transparent 12%, #000 16%),
      repeating-linear-gradient(100deg, #3b82f6 10%, #a5b4fc 15%, #93c5fd 20%, #ddd6fe 25%, #60a5fa 30%);
    background-size: 300%, 200%;
    background-position: 50% 50%, 50% 50%;
    filter: blur(10px);
    opacity: 0.45;
    animation: aurora 60s linear infinite;
    will-change: background-position;
    /* Fade out toward bottom-left — keeps text area readable */
    mask-image: radial-gradient(ellipse at 100% 0%, black 10%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 100% 0%, black 10%, transparent 70%);
    pointer-events: none;
  }

  /* Second pass with mix-blend-difference creates the shimmer depth */
  .hero__aurora::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(100deg, #000 0%, #000 7%, transparent 10%, transparent 12%, #000 16%),
      repeating-linear-gradient(100deg, #3b82f6 10%, #a5b4fc 15%, #93c5fd 20%, #ddd6fe 25%, #60a5fa 30%);
    background-size: 200%, 100%;
    background-attachment: fixed;
    animation: aurora 60s linear infinite;
    mix-blend-mode: difference;
  }

  @keyframes aurora {
    from { background-position: 50% 50%, 50% 50%; }
    to   { background-position: 350% 50%, 350% 50%; }
  }

  /* ---- Keyframes ---- */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: none; }
  }

  @keyframes slideUp {
    from { transform: translateY(110%); }
    to   { transform: none; }
  }

/* ---- Responsive ---- */
  @media (max-width: 600px) {
    .hero__name-last {
      -webkit-text-stroke-width: 1.5px;
    }

    .hero__accent {
      opacity: 0.4;
    }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .hero__name-first,
    .hero__name-last,
    .hero__label,
    .hero__positioning,
    .hero__credential,
    .hero__ctas {
      animation: none;
    }

    .hero__accent-ring {
      animation: none;
    }

    .hero__aurora,
    .hero__aurora::after {
      animation: none;
    }

  }
</style>
